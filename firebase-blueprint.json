{
  "entities": {
    "Student": {
      "title": "Student",
      "description": "Represents a student and their grades/payment status.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "seat_number": { "type": "string" },
        "national_id": { "type": "string" },
        "full_name": { "type": "string" },
        "grade": { "type": "string" },
        "percentage": { "type": "number" },
        "school_name": { "type": "string" },
        "school_year": { "type": "string" },
        "price": { "type": "number" },
        "is_paid": { "type": "boolean" },
        "subject_grades": { "type": "object" },
        "certificate_hash": { "type": "string" }
      },
      "required": ["seat_number", "national_id", "full_name", "grade", "percentage", "school_name", "school_year", "price", "is_paid", "certificate_hash"]
    },
    "Payment": {
      "title": "Payment",
      "description": "Represents a transaction payment record.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "student_id": { "type": "string" },
        "amount": { "type": "number" },
        "transaction_id": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "success", "failed"] },
        "payment_method": { "type": "string" },
        "created_at": { "type": "string" },
        "updated_at": { "type": "string" }
      },
      "required": ["student_id", "amount", "transaction_id", "status", "payment_method", "created_at"]
    },
    "GatewayConfig": {
      "title": "GatewayConfig",
      "description": "Kashier payment gateway configuration.",
      "type": "object",
      "properties": {
        "merchantId": { "type": "string" },
        "apiKey": { "type": "string" },
        "apiSecret": { "type": "string" },
        "mode": { "type": "string", "enum": ["simulator", "sandbox", "production"] }
      },
      "required": ["merchantId", "apiKey", "apiSecret", "mode"]
    }
  },
  "firestore": {
    "students": {
      "schema": "#/entities/Student",
      "description": "A collection of student profiles and educational certificates."
    },
    "payments": {
      "schema": "#/entities/Payment",
      "description": "Payment transactions for certificates."
    },
    "gatewayConfig": {
      "schema": "#/entities/GatewayConfig",
      "description": "Singleton configuration document for Kashier integration."
    }
  }
}
